server {
    listen 80;
    server_name priceradar.com www.priceradar.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name priceradar.com www.priceradar.com;

    ssl_certificate     /etc/letsencrypt/live/priceradar.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/priceradar.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # React SPA — static build
    root /var/www/priceradar/frontend/dist;
    index index.html;

    # All SPA routes → index.html (client-side routing)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Django — API, staff, admin, catalog, telegram
    location ~ ^/(api|staff|admin|comparar|producto|cupones|go|telegram)/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Django static files (whitenoise serves them, but nginx intercepts for performance)
    location /static/ {
        alias /var/www/priceradar/staticfiles/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
