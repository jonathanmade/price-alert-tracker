{
  "rewrites": [
    {
      "source": "/staff/:path*",
      "destination": "https://web-dev-cda5.up.railway.app/staff/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://web-dev-cda5.up.railway.app/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://web-dev-cda5.up.railway.app/admin/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
