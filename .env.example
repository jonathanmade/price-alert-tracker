SECRET_KEY=cambia-esto-por-una-clave-segura

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=          # Project Settings → JWT Keys → JWT Secret

# CORS — debe coincidir con el puerto de Vite (3000 en desarrollo)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# URL del frontend React (para links en el panel staff)
FRONTEND_URL=http://localhost:3000

# Ojo: codifica caracteres especiales en la password (&→%26, /→%2F)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379/0

SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@priceradar.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=          # @BotFather → /newbot
TELEGRAM_BOT_NAME=           # Username del bot sin @, ej: PriceRadarBot
TELEGRAM_WEBHOOK_SECRET=     # Token aleatorio para validar webhooks (recomendado)

# Solo en producción
# ALLOWED_HOSTS=priceradar.com
